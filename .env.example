# Shared local database connection used by portfolio projects.
# Copy this file to .env locally and adjust the values for your machine.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/data_projects

# Project 1
SALES_INPUT_PATH=project_1_csv_pipeline/data/sales_data.csv
SALES_TABLE_NAME=sales

# Project 2
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast?latitude=26.7&longitude=88.4&current_weather=true
WEATHER_TABLE_NAME=weather_data
WEATHER_LOAD_MODE=append

# Project 3
DATA_QUALITY_INPUT_PATH=project_3_data_cleaning/data/raw_data.csv
DATA_QUALITY_CLEAN_OUTPUT_PATH=project_3_data_cleaning/data/clean_data.csv
DATA_QUALITY_REJECTED_OUTPUT_PATH=project_3_data_cleaning/data/rejected_records.csv

# Project 4
JSON_ORDERS_INPUT_PATH=project_4_json_pipeline/data/orders.json
JSON_ORDERS_TABLE_NAME=orders
JSON_ORDER_ITEMS_TABLE_NAME=order_items
JSON_LOAD_MODE=replace

# Project 5
WAREHOUSE_INPUT_PATH=project_5_data_warehouse/data/sales_data.csv

# Project 6
ECOMMERCE_ORDERS_PATH=project_6_ecommerce_pipeline/data/orders.csv
ECOMMERCE_CUSTOMERS_PATH=project_6_ecommerce_pipeline/data/customers.csv
ECOMMERCE_PRODUCTS_PATH=project_6_ecommerce_pipeline/data/products.csv

# Project 7
LOG_INPUT_PATH=project_7_log_pipeline/data/app.log
LOG_STATE_PATH=project_7_log_pipeline/state/log_state.json
